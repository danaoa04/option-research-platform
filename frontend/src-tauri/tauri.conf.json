{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Option Research Platform",
  "version": "1.0.0-rc.1",
  "identifier": "io.optionresearch.platform",
  "build": { "beforeDevCommand": "npm run dev", "beforeBuildCommand": "npm run build", "devUrl": "http://localhost:1420", "frontendDist": "../dist" },
  "app": { "windows": [{ "title": "Option Research Platform", "width": 1440, "height": 900, "minWidth": 900, "minHeight": 640 }], "security": { "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; frame-src 'none'; base-uri 'none'" } },
  "bundle": { "active": true, "targets": "all", "externalBin": ["binaries/orp-backend"], "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.png"], "category": "DeveloperTool", "copyright": "Copyright 2026 Option Research Platform contributors", "fileAssociations": [{ "ext": ["orp-workspace"], "name": "Option Research Platform Workspace", "description": "Versioned Option Research Platform workspace", "role": "Editor" }], "macOS": { "minimumSystemVersion": "12.0", "hardenedRuntime": true } }
}
